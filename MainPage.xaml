<Page
    x:Class="XboxYouTube.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">

    <Grid>
        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Background="#FF0A0A0A" Canvas.ZIndex="10">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock
                    Text="&#9654;  YouTube"
                    FontSize="52"
                    FontWeight="Light"
                    Foreground="White"
                    HorizontalAlignment="Center"
                    Margin="0,0,0,16"/>
                <TextBlock
                    Text="Loading..."
                    FontSize="18"
                    Foreground="#888888"
                    HorizontalAlignment="Center"/>
                <ProgressRing
                    x:Name="LoadingRing"
                    IsActive="True"
                    Width="48"
                    Height="48"
                    Foreground="#FF0000"
                    Margin="0,20,0,0"
                    HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- WebView -->
        <WebView
            FocusVisualPrimaryBrush="Transparent"
            FocusVisualSecondaryBrush="Transparent"
            x:Name="YoutubeWebView"
            NavigationCompleted="YoutubeWebView_NavigationCompleted"
            NavigationStarting="YoutubeWebView_NavigationStarting"
            ContentLoading="YoutubeWebView_ContentLoading"
            ScriptNotify="YoutubeWebView_ScriptNotify"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"/>

        <!-- Controller hints -->
        <Border
            x:Name="ControllerHints"
            VerticalAlignment="Bottom"
            Background="#CC000000"
            Padding="20,10"
            Opacity="0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="A=Select  " Foreground="White" FontSize="14"/>
                <TextBlock Text="B=Back  " Foreground="White" FontSize="14"/>
                <TextBlock Text="X=Play/Pause  " Foreground="White" FontSize="14"/>
                <TextBlock Text="Y=Reload  " Foreground="White" FontSize="14"/>
                <TextBlock Text="LB/RB=Seek" Foreground="White" FontSize="14"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
